{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },

  "metrics": {
    "namespace": "ServerInventory",

    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "InstanceType": "${aws:InstanceType}",
      "ImageId": "${aws:ImageId}",
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}"
    },

    "aggregation_dimensions": [
      [
        "AutoScalingGroupName"
      ]
    ],

    "metrics_collected": {

      "cpu": {
        "measurement": [
          "cpu_usage_idle",
          "cpu_usage_user",
          "cpu_usage_system"
        ],
        "totalcpu": true,
        "metrics_collection_interval": 60
      },

      "disk": {
        "measurement": [
          "used_percent"
        ],
        "resources": [
          "*"
        ],
        "metrics_collection_interval": 60
      },

      "diskio": {
        "measurement": [
          "reads",
          "writes",
          "read_bytes",
          "write_bytes"
        ],
        "resources": [
          "*"
        ],
        "metrics_collection_interval": 60
      },

      "mem": {
        "measurement": [
          "mem_used_percent"
        ],
        "metrics_collection_interval": 60
      },

      "swap": {
        "measurement": [
          "swap_used_percent"
        ],
        "metrics_collection_interval": 60
      },

      "net": {
        "measurement": [
          "bytes_sent",
          "bytes_recv",
          "packets_sent",
          "packets_recv"
        ],
        "resources": [
          "*"
        ],
        "metrics_collection_interval": 60
      }
    }
  },

  "logs": {

    "logs_collected": {

      "files": {

        "collect_list": [

          {
            "file_path": "/opt/tomcat/logs/catalina.out",
            "log_group_name": "/server-inventory/tomcat",
            "log_stream_name": "{instance_id}"
          },

          {
            "file_path": "/opt/tomcat/logs/*.log",
            "log_group_name": "/server-inventory/tomcat",
            "log_stream_name": "{instance_id}"
          },

          {
            "file_path": "/var/log/messages",
            "log_group_name": "/server-inventory/system",
            "log_stream_name": "{instance_id}"
          },

          {
            "file_path": "/var/log/cloud-init.log",
            "log_group_name": "/server-inventory/cloud-init",
            "log_stream_name": "{instance_id}"
          },

          {
            "file_path": "/var/log/cloud-init-output.log",
            "log_group_name": "/server-inventory/cloud-init",
            "log_stream_name": "{instance_id}"
          }

        ]
      }
    }
  }
}
